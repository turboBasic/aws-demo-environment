# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Terraform
*.tf        text eol=lf
*.tfvars    text eol=lf
*.hcl       text eol=lf
*.tftpl     text eol=lf

# Shell scripts
*.sh        text eol=lf

# Python
*.py        text eol=lf diff=python

# Web
*.html      text eol=lf diff=html
*.js        text eol=lf
*.css       text eol=lf

# Data / config
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf

# Docs
*.md        text eol=lf
*.markdown  text eol=lf

# Binary assets
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
